# Site Identity
title: "Amit Kumar Shaw"
name: "Amit Kumar Shaw"
description: "Enterprise Architect | SAP BRIM, RAR, FSCM & FI Specialist"
remote_theme: "raviriley/agency-jekyll-theme"
theme: null

# Author Branding
author:
  name: "Amit Kumar Shaw"
  avatar: "/assets/images/profile.jpg"
  job_title: "Senior SAP Architect"
  location: "Atlanta, GA"

# Navigation Menu (Agency specific)
nav:
  - { name: "About", link: "/about/" }
  - { name: "Expertise", link: "#expertise" }
  - { name: "Expertise", link: "/projects/" }
  - { name: "Library", link: "/library/" }
  - { name: "Interests", link: "/interests/" }
  - { name: "Contact", link: "/contact/" }

# Social Links (Used by the theme for the footer/contact section)
social:
  linkedin: "akumarshaw"
  whatsapp: "917337327827"
  email: "contact@amitkshaw.com"

# Collections Strategy (For your 13+ Articles and Expertise pages)
collections:
  library:
    output: true
    permalink: /library/:path/
  expertise:
    output: true
    permalink: /expertise/:path/

# Build Settings for GitHub Pages
plugins:
  - jekyll-remote-theme
  - jekyll-include-cache
  - jekyll-sitemap

# This ensures that even if a file has a weird layout name, it uses 'page'
defaults:
  - scope:
      path: ""
    values:
      layout: "default"
  - scope:
      path: "_library"
    values:
      layout: "default"
